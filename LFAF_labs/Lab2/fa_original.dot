digraph "Variant 12 - Original NDFA" {
  rankdir=LR;
  node [shape=circle, style=filled, fillcolor=white];
  "q2" [shape=doublecircle, fillcolor="#90ee90"];
  "q0" [fillcolor="#add8e6"];
  __start__ [shape=none, label=""];
  __start__ -> "q0";
  "q0" -> "q0" [label="b"];
  "q0" -> "q1" [label="a"];
  "q1" -> "q1" [label="c"];
  "q1" -> "q2" [label="a"];
  "q2" -> "q3" [label="a"];
  "q3" -> "q1" [label="a"];
  "q3" -> "q3" [label="a"];
  label="Variant 12 - Original NDFA";
  fontsize=14;
}
